# =========================
# FLASK
# =========================
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=change-me

# =========================
# DATABASE
# =========================
DATABASE_URL=postgresql://corelabtech_user:change-me@db:5432/corelabtech

# =========================
# SECURITY
# =========================
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SECURE=False
REMEMBER_COOKIE_HTTPONLY=True

# =========================
# UPLOADS
# =========================
UPLOAD_FOLDER=data/uploads
MAX_CONTENT_LENGTH=52428800

# =========================
# PLAYWRIGHT
# =========================
PLAYWRIGHT_WORKERS=1
PLAYWRIGHT_BASE_URL=http://127.0.0.1:5000

# =========================
# PERFORMANCE / GATLING
# =========================
PERFORMANCE_TESTING=false
GATLING_REPORTS_PATH=tests/performance/gatling/target/gatling

# =========================
# AI SETTINGS
# =========================
AI_MODE=research
AI_ENABLE_ANOMALY=True
AI_ENABLE_TRENDS=True
AI_ANALYSIS_TIMEOUT=120

# =========================
# LOGGING
# =========================
LOG_LEVEL=INFO

# =========================
# FUTURE CLOUD DEPLOYMENT
# =========================
APP_ENV=local
# =========================
# GUNICORN
# =========================
GUNICORN_WORKERS=1
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=300
# =========================
# MONITORING
# =========================
ENABLE_METRICS=true
PROMETHEUS_ENABLED=false